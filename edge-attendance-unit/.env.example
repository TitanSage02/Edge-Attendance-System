# ==========================================================
# Edge Attendance Unit (Raspberry Pi) — example configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ==========================================================

# ---- Face recognition (InsightFace) ----
INSIGHTFACE_MODEL=buffalo_l
FACE_DETECTION_THRESHOLD=0.5
# Minimum cosine similarity (0–1) to accept a face match. Below it, the unit
# reports "no match" and falls back to RFID (the mandatory second factor).
# Relaxed during the pilot to reduce false rejections under variable lighting;
# tested range 0.6–0.8. Calibrate on-device for your conditions.
SIMILARITY_THRESHOLD=0.6
MIN_FACE_SIZE=50
CAMERA_RESOLUTION_WIDTH=640
CAMERA_RESOLUTION_HEIGHT=480

# ---- GPIO pin mapping (BCM numbering) ----
RED_LED_PIN=18
GREEN_LED_PIN=16
BLUE_LED_PIN=15
BUZZER_PIN=12
RFID_PIN=22

# ---- VL53L0X distance sensor ----
DISTANCE_THRESHOLD_MM=100.0

# ---- Backend API ----
BASE_URL='http://<backend-host>:8000'
# Per-module API key issued by the backend (Settings > Modules). Keep secret.
API_KEY='<your-module-api-key>'

# ---- MQTT broker ----
MQTT_BROKER='<mqtt-host>'
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USERNAME='<mqtt-username>'
MQTT_PASSWORD='<mqtt-password>'

# ---- TLS for secure MQTT ----
USE_TLS=true
MQTT_CA_CERT='/etc/ssl/certs/ca-certificates.crt'
# MQTT_CLIENT_CERT=  # Client cert (optional, for mutual TLS)
# MQTT_CLIENT_KEY=   # Client key  (optional, for mutual TLS)
MQTT_INSECURE_TLS=false  # true for dev/test only

# ---- Module identity ----
MODULE_ID=1

# ---- Local config web portal (Flask) ----
# Session signing key for the on-device configuration portal.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=<random-32-byte-hex>

# ---- Debug ----
DEBUG_MODE=false
