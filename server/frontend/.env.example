# Exemple de configuration pour production
# Copiez ce fichier vers .env.local et modifiez les valeurs

# URL de l'API Backend - MODIFIEZ CETTE VALEUR
VITE_API_URL=https://votre-backend-ngrok.ngrok.io/api/v1

# URL WebSocket MQTT (optionnel)
VITE_MQTT_WS_URL=wss://votre-mqtt-ngrok.ngrok.io

# Mode de développement
VITE_DEV_MODE=false

# Configuration de débogage  
VITE_DEBUG=false

# Configuration des timeouts API (en millisecondes)
# Timeout par défaut pour les requêtes normales (2 minutes recommandé pour backend local)
VITE_API_TIMEOUT=120000

# Timeout pour les opérations longues (exports, sauvegardes) - 5 minutes
VITE_API_LONG_TIMEOUT=300000

# Timeout pour les opérations très longues (IA, embeddings) - 10 minutes
VITE_API_HEAVY_TIMEOUT=600000
