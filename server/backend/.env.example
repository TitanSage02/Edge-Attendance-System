# ==========================================================
# Server Backend (FastAPI) — example configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ==========================================================

# ---- PostgreSQL ----
POSTGRES_DB=attendance_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<strong-db-password>
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:<strong-db-password>@localhost:5432/attendance_db

# ---- Security & authentication ----
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=<random-32-byte-hex>
JWT_REFRESH_SECRET=<random-32-byte-hex>
ACCESS_TTL_MINUTES=60
REFRESH_TTL_DAYS=7
ALGORITHM=HS256
# AES-256 key for biometric embedding encryption. Generate with:
# python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=<base64-32-byte-key>

# ---- Server & API ----
DEBUG=false
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO
ENV=production

# ---- MQTT ----
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=<mqtt-backend-user>
MQTT_USER=<mqtt-backend-user>
MQTT_PASSWORD=<mqtt-backend-password>
MQTT_DEVICES_PASSWORD=<mqtt-devices-password>
MQTT_USE_TLS=false

# ---- Email (SMTP) ----
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_USER=<smtp-user>
SMTP_PASSWORD=<smtp-password>
SMTP_FROM=no-reply@example.org
SMTP_FROM_NAME=Edge Attendance
SMTP_STARTTLS=true

# ---- WebSocket ----
WS_MAX_CONNECTIONS=1000
WS_MAX_CONNECTIONS_PER_CHANNEL=200
WS_HISTORY_SIZE=100

# ---- Paths & storage ----
LOG_DIR=logs
DATA_PATH=data
LOGS_PATH=logs

# ---- Initial admin account ----
FIRST_USER_EMAIL=admin@example.org
FIRST_USER_FIRST_NAME=Admin
FIRST_USER_LAST_NAME=User

# ---- Chatbot (RAG, optional) ----
USE_CHATBOT=true
CHATBOT_MODEL_NAME=gemini-2.0-flash-lite-001
CHATBOT_API_KEY=<google-generative-ai-key>

# ---- Docker Compose ports ----
HTTP_PORT=80
HTTPS_PORT=443

# ---- Cloudflare Tunnel (optional) ----
CLOUDFLARE_TUNNEL_TOKEN=<cloudflare-tunnel-token>
