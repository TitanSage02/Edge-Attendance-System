# Normalize line endings: LF in the repo, native on checkout where relevant.
* text=auto eol=lf

# Shell scripts and configs must stay LF (executed on Linux / Raspberry Pi)
*.sh text eol=lf
*.service text eol=lf
*.conf text eol=lf
Dockerfile text eol=lf

# Treat known binaries as binary (no EOL conversion, no diff noise)
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pdf binary
*.svg binary
*.onnx binary
*.zip binary
*.kicad_pcb binary
*.kicad_sch binary
